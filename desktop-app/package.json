{
  "name": "photoflow-desktop",
  "productName": "PhotoFlow AI",
  "private": true,
  "version": "0.1.0",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:web": "vite",
    "dev:electron": "wait-on tcp:5173 && electron .",
    "build": "npm run build:web",
    "build:web": "tsc && vite build",
    "preview": "vite preview",
    "electron": "electron ."
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.22.0",
    "face-api.js": "^0.22.2",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.1",
    "electron": "^35.1.5",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "wait-on": "^8.0.3"
  }
}
